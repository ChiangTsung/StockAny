#!/bin/sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN=python3
elif command -v python >/dev/null 2>&1; then
  PYTHON_BIN=python
else
  echo "StockAny requires python3 or python. Install Python 3 and rerun ./stockany ..." >&2
  exit 1
fi

if ! "$PYTHON_BIN" -c 'import sys' >/dev/null 2>&1; then
  echo "StockAny could not start the Python interpreter. Check your Python installation and rerun ./stockany ..." >&2
  exit 1
fi

exec "$PYTHON_BIN" "$ROOT_DIR/scripts/stockany.py" "$@"
